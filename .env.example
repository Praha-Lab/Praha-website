# Praha Labs — environment variables
# Copy this to .env.local and fill in the values.

# Modal deployment URL for Praha Voice-1 TTS
# After running `modal deploy modal_app.py`, set this to the deployed URL, e.g.:
#   https://your-org--praha-voice-1-generate.modal.run
PRAHA_TTS_URL=
PRAHA_TURBO_TTS_URL=

# Modal deployment URL for Higgs TTS 3 4B via SGLang Omni
HIGGS_TTS_URL=

# Modal deployment URL for OmniVoice multilingual TTS
OMNIVOICE_TTS_URL=
